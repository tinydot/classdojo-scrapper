# ClassDojo credentials
CLASSDOJO_EMAIL=your@email.com
CLASSDOJO_PASSWORD=yourpassword

# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# SMTP — example below uses Gmail App Password
# For Gmail: enable 2FA, then generate an App Password at
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your@gmail.com
EMAIL_TO=your@gmail.com       # comma-separate for multiple recipients

# Optional
DB_PATH=classdojo_seen.db     # path to SQLite file (default: current dir)
ATTACHMENTS_DIR=attachments   # folder where downloaded files are saved (default: ./attachments)
HEADLESS=true                 # set to false to watch the browser during testing
